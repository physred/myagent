# ===== 模型提供者 =====
# 可选值: openai (默认), claude
PROVIDER_TYPE=claude

# OpenAI 兼容接口配置
OPENAI_API_KEY=
OPENAI_MODEL_NAME=
OPENAI_API_BASE=

# Anthropic Claude API 配置（PROVIDER_TYPE=claude 时生效，缺省 fallback 到 OpenAI 同名变量）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=
ANTHROPIC_API_BASE=

# ===== Agent 配置 =====
# 工作目录，用于保存会话与记忆文件
AGENT_WORKSPACE=

# 启用 Hook 事件日志（设为 1 写入 workspace/hook.log）
ENABLE_HOOK_LOG=1

# ===== RAG 检索配置 =====
RAG_API_URL=
RAG_SEARCH_MODE=
RAG_TOP_K=
RAG_MAX_CONTEXT_TOKENS=
